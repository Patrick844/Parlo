# Copy to .env and fill in real values. Never commit the real .env.

# OpenAI — powers the respondent chat and AI insights (model: gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Creator login password for the dashboard
ADMIN_PASSWORD=pick-a-strong-password

# Secret for signing JWTs — any long random string
SECRET_KEY=generate-a-long-random-string

# Where the browser app reaches the API (baked into the frontend build)
VITE_API_BASE=http://localhost:8200

# Allowed CORS origin — where the frontend is served from
FRONTEND_URL=http://localhost:3200
