# Copy to .env and fill in real values. Never commit the real .env.

# OpenAI — powers the respondent chat and AI insights (model: gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Database — full connection string. A managed URL with query params works as-is,
# e.g. Neon: postgresql://user:pass@host/db?sslmode=require&channel_binding=require
# Left unset, the app falls back to the local dev Postgres.
# DATABASE_URL=postgresql://parlo:parlo@localhost:5433/parlo

# DEPRECATED — no longer used. Guest access is email-only (no password), so this
# is ignored. Safe to delete.
# ADMIN_PASSWORD=pick-a-strong-password

# Secret for signing JWTs — any long random string
SECRET_KEY=generate-a-long-random-string

# Where the browser app reaches the API (baked into the frontend build)
VITE_API_BASE=http://localhost:8200

# PostHog product analytics (optional). A public project key is already baked
# into the production build, so leaving this BLANK is fine. Set it only to point
# at a DIFFERENT project. Host defaults to PostHog EU cloud.
VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://eu.i.posthog.com   # use us.i.posthog.com for US cloud

# Allowed CORS origin — where the frontend is served from
FRONTEND_URL=http://localhost:3200
